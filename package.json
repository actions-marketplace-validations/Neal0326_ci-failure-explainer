{
  "name": "ci-failure-explainer",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action that explains failed CI jobs with OpenAI.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.8.2"
  }
}
